# ACEN Gravity — environment template
# Copy to `.env` (gitignored). Never commit real secrets.

# --- App ---
APP_ENV=development
APP_SECRET_KEY=change-me-locally-not-for-production
APP_HOST=127.0.0.1
APP_PORT=8000

# --- Database ---
# POC V1 default = SQLite, per D-0024 (temporary while podman/WSL is unblocked).
# Same SQLAlchemy + Alembic code targets Postgres later — only this URL changes.
DATABASE_URL=sqlite:///./var/gravity.db
# Postgres alternative (uncomment + start `podman compose up -d`):
#DATABASE_URL=postgresql+psycopg://gravity:gravity@localhost:5432/gravity

# --- Logging ---
LOG_LEVEL=INFO
